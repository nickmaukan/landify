---
const stats = [
    { icon: '👶', value: '5,000+', label: 'Pacientes atendidos' },
    { icon: '⭐', value: '4.9', label: 'Calificación Google' },
    { icon: '📅', value: '12+', label: 'Años de experiencia' }
];
---

<section class="gradient-hero min-h-screen flex items-center pt-24 pb-16 relative overflow-hidden" aria-labelledby="hero-heading">
    <!-- Decorative blobs -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-teal-500/10 blob opacity-60" aria-hidden="true"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-pink-200/20 blob opacity-50" style="animation-delay: -4s;" aria-hidden="true"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <!-- Left Content -->
            <div class="space-y-8">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur rounded-full shadow-sm border border-teal-100">
                    <span class="w-2 h-2 bg-teal-600 rounded-full animate-pulse" aria-hidden="true"></span>
                    <span class="text-sm font-medium text-teal-600">Disponible para teleconsulta hoy</span>
                </div>
                
                <h1 id="hero-heading" class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
                    Tu hijo merece la <span class="text-teal-600">mejor atención</span> médica
                </h1>
                
                <p class="text-xl text-slate-600 leading-relaxed">
                    Soy la <strong>Dra. Carolinaidez</strong>, pediatra con más de <strong>12 años</strong> cuidando a niños desde recién nacidos hasta adolescentes. Aquí, cada consulta es con tiempo, dedicación y mucho cariño.
                </p>
                
                <div class="flex flex-wrap gap-4">
                    <a href="https://wa.me/593998815416?text=Hola%20Dra.%20Carolinaidez,%20quisiera%20agendar%20una%20cita%20para%20mi%20hijo/a" target="_blank" rel="noopener noreferrer" class="px-8 py-4 bg-teal-600 text-white rounded-full font-semibold hover:bg-teal-700 transition flex items-center gap-2 shadow-xl shadow-teal-600/30 text-lg">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        Agendar Cita por WhatsApp
                    </a>
                    <a href="tel:+593999123456" class="px-8 py-4 bg-white text-teal-600 border-2 border-teal-600 rounded-full font-semibold hover:bg-teal-600 hover:text-white transition flex items-center gap-2 text-lg">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                        Llamar Ahora
                    </a>
                </div>
                
                <!-- Quick stats -->
                <div class="flex flex-wrap gap-6 pt-4">
                    {stats.map(stat => (
                        <div class="flex items-center gap-2">
                            <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center" aria-hidden="true">
                                <span class="text-lg">{stat.icon}</span>
                            </div>
                            <div>
                                <p class="font-bold text-2xl text-slate-800">{stat.value}</p>
                                <p class="text-sm text-slate-500">{stat.label}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
            
            <!-- Right Content - Doctor Image -->
            <div class="relative">
                <div class="relative rounded-3xl overflow-hidden shadow-2xl float">
                    <img 
                        src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=600&h=700&fit=crop" 
                        alt="Dra. Carolinaidez - Pediatra en Quito, Ecuador" 
                        class="w-full h-auto object-cover"
                        loading="eager"
                        width="600"
                        height="700"
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/20 to-transparent"></div>
                </div>
                <!-- Floating card -->
                <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 shadow-xl border border-slate-100">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center" aria-hidden="true">
                            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-slate-800">Miembro de</p>
                            <p class="text-sm text-slate-500">Sociedad Ecuatoriana de Pediatría</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .gradient-hero { background: linear-gradient(135deg, #FEF7F0 0%, #F0FDFA 50%, #ECFEFF 100%); }
    .blob { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; animation: blob 8s ease-in-out infinite; }
    @keyframes blob { 0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; } 50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; } }
    .float { animation: float 6s ease-in-out infinite; }
    @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-20px); } }
</style>