---
const schedule = [
    { day: 'Lunes', time: '8:00 AM - 6:00 PM', highlight: true },
    { day: 'Martes', time: '8:00 AM - 6:00 PM', highlight: true },
    { day: 'Miércoles', time: '8:00 AM - 6:00 PM', highlight: true },
    { day: 'Jueves', time: '8:00 AM - 6:00 PM', highlight: true },
    { day: 'Viernes', time: '8:00 AM - 6:00 PM', highlight: true },
    { day: 'Sábado', time: '9:00 AM - 1:00 PM', highlight: true, accent: true },
    { day: 'Domingo', time: 'Cerrado', highlight: false, closed: true }
];

const paymentMethods = ['Efectivo', 'Tarjeta crédito/débito', 'Transferencia', 'IESS', 'Seguros privados'];
---

<section id="contacto" class="py-24 bg-slate-900 text-white" aria-labelledby="contact-heading">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16">
            <div>
                <span class="inline-block px-4 py-2 bg-teal-500/20 text-teal-300 rounded-full text-sm font-semibold mb-4">Contacto</span>
                <h2 id="contact-heading" class="text-4xl md:text-5xl font-bold mb-6">Agenda tu cita</h2>
                <p class="text-xl text-slate-300 mb-8">Estoy aquí para ayudarte. Elige el canal que te sea más cómodo.</p>
                
                <div class="space-y-4">
                    <a href="https://wa.me/593998815416?text=Hola%20Dra.%20Carolinaidez,%20quisiera%20agendar%20una%20cita%20para%20mi%20hijo/a" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-4 bg-white/10 rounded-2xl hover:bg-white/20 transition">
                        <div class="w-12 h-12 rounded-full bg-emerald-500 flex items-center justify-center" aria-hidden="true">
                            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-lg">WhatsApp</p>
                            <p class="text-slate-300">+593 99 812 3456</p>
                        </div>
                    </a>
                    
                    <a href="tel:+593999123456" class="flex items-center gap-4 p-4 bg-white/10 rounded-2xl hover:bg-white/20 transition">
                        <div class="w-12 h-12 rounded-full bg-blue-500 flex items-center justify-center" aria-hidden="true">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-lg">Llamar al consultorio</p>
                            <p class="text-slate-300">+593 2 234 5678</p>
                        </div>
                    </a>
                    
                    <div class="flex items-center gap-4 p-4 bg-white/10 rounded-2xl">
                        <div class="w-12 h-12 rounded-full bg-amber-500 flex items-center justify-center" aria-hidden="true">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-lg">Consultorio</p>
                            <p class="text-slate-300">Av. Los Shyris N35-42 y Naciones Unidas</p>
                            <p class="text-slate-400 text-sm">Quito, Ecuador</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div>
                <h3 class="text-2xl font-bold mb-6">Horarios de Atención</h3>
                <div class="bg-white/10 rounded-2xl p-8">
                    <table class="w-full" role="table" aria-label="Horarios de atención">
                        <tbody class="divide-y divide-white/10">
                            {schedule.map(item => (
                                <tr>
                                    <td class={`py-3 font-medium ${item.closed ? 'text-slate-400' : ''}`}>{item.day}</td>
                                    <td class={`py-3 text-right ${item.accent ? 'text-amber-300' : item.highlight ? 'text-teal-300' : 'text-slate-500'}`}>
                                        {item.time}
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-8">
                    <h4 class="font-semibold mb-4">Formas de pago aceptadas</h4>
                    <div class="flex flex-wrap gap-3">
                        {paymentMethods.map(method => (
                            <span class="px-4 py-2 bg-white/10 rounded-full text-sm">{method}</span>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>