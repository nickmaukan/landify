---
import '@astrojs/tailwind/tailwind.css';
import SEOHead from '../components/SEOHead.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title = "Dra. Carolinaidez | Pediatra en Quito - Consulta Infantil + Teleconsulta";
const description = "Dra. Carolinaidez, pediatra en Quito con +12 años de experiencia. Control del niño sano, vacunas, enfermedades. Consulta presencial y teleconsulta. Agenda tu cita hoy.";
const ogImage = "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=1200";
const canonicalURL = "https://dra-carolinaidez.com";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO Optimization -->
    <SEOHead 
        title={title}
        description={description}
        canonical={canonicalURL}
        ogImage={ogImage}
    />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Favicon SVG -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <!-- JSON-LD Structured Data - MedicalOrganization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Physician",
      "name": "Dra. Carolinaidez",
      "description": "Pediatra y especialista en puericultura en Quito, Ecuador",
      "medicalSpecialty": "Pediatric",
      "image": "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=600",
      "telephone": "+593999123456",
      "email": "contacto@dra-carolinaidez.com",
      "url": "https://dra-carolinaidez.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. Los Shyris N35-42 y Naciones Unidas",
        "addressLocality": "Quito",
        "addressCountry": "EC"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-0.1807",
        "longitude": "-78.4678"
      },
      "openingHoursSpecification": [
        {"@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "08:00", "closes": "18:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "13:00"}
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "127"
      },
      "sameAs": []
    }
    </script>
    
    <!-- JSON-LD BreadcrumbList -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://dra-carolinaidez.com"},
        {"@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://dra-carolinaidez.com/#servicios"},
        {"@type": "ListItem", "position": 3, "name": "Sobre la Dra.", "item": "https://dra-carolinaidez.com/#sobre-mi"}
      ]
    }
    </script>
    
    <!-- JSON-LD FAQPage -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿A qué edad debo llevar a mi hijo al pediatra?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Se recomienda la primera visita al nacer o durante la primera semana de vida, luego seguir el esquema de controles de niño sano: 1, 2, 4, 6, 9, 12, 18 y 24 meses, y posteriormente una vez al año."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es la teleconsulta pediátrica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La teleconsulta es una consulta médica virtual a través de videollamada. Es ideal para seguimientos, consultas no urgentes y orientación rápida. La Dra. Carolinaidez ofrece este servicio para su comodidad."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuáles son los horarios de atención?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Lunes a viernes de 8:00 AM a 6:00 PM. Sábados de 9:00 AM a 1:00 PM. Domingos cerrado. Las citas por WhatsApp están disponibles las 24 horas."
          }
        }
      ]
    }
    </script>
</head>
<body class="bg-warm-50 text-slate-800">
    <!-- Skip to main content for accessibility -->
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded">
        Saltar al contenido principal
    </a>

    <Nav />
    
    <main id="main">
        <Hero />
        <TrustBar />
        <Services />
        <About />
        <Testimonials />
        <Contact />
    </main>
    
    <Footer />
    
    <!-- WhatsApp Floating Button -->
    <a 
        href="https://wa.me/593998815416?text=Hola%20Dra.%20Carolinaidez,%20quisiera%20agendar%20una%20cita%20para%20mi%20hijo/a" 
        target="_blank" 
        rel="noopener noreferrer"
        class="fixed bottom-6 right-6 z-50 w-16 h-16 bg-emerald-500 rounded-full flex items-center justify-center shadow-2xl hover:bg-emerald-600 transition hover:scale-110"
        aria-label="Contactar por WhatsApp"
    >
        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
    </a>
</body>
</html>